# Virtual environment — never commit this.
# Anyone can recreate it with: pip install -r requirements.txt
HackEnv/
venv/
.venv/
env/

# API keys — NEVER commit this. If pushed to GitHub (even private),
# your keys are exposed and could be used to rack up charges on your accounts.
.env

# Python bytecode cache — auto-generated by Python when it runs your code.
# These are machine-specific and change constantly; no value in tracking them.
__pycache__/
*.py[cod]

# Session output files — generated when the server shuts down.
# These are lecture artifacts, not source code.
notes_*.md
transcript_*.md

# Claude Code local settings (machine-specific, not useful to collaborators)
.claude/

# OS and editor clutter
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
